  "attributeSchema": {
    "assetId": "Stable id used by AI and importer rules.",
    "assetPath": "Unity asset path.",
    "guideRole": "Role from the Tiny Swords tilemap guide.",
    "terrainPalette": "Tilemap color/palette when applicable.",
    "tileSizePixels": "Expected source tile size.",
    "pixelsPerUnit": "Unity PPU for consistent pixel scale.",
    "walkable": "Whether a unit can stand on this by default.",
    "blocksMovement": "Whether this blocks movement by default.",
    "elevationLevel": "Default logical height. Use layer context for repeated elevated levels.",
    "connectsElevation": "Whether this connects lower and upper terrain.",
    "renderBand": "Stable render ordering band.",
    "colliderPolicy": "none, blockMovement, trigger, or contextual.",
    "placementRule": "Human-readable placement rule for level design.",
    "requiresLayerContext": "True when an atlas contains pieces with mixed gameplay meanings."
  },
